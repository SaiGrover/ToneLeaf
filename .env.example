# The browser talks only to the Python service running on this device.
NEXT_PUBLIC_TONELEAF_API=http://127.0.0.1:8765
# For a build served by the same FastAPI process, use: same-origin

# Local API bind defaults. The production Dockerfile overrides these.
TONELEAF_HOST=127.0.0.1
TONELEAF_PORT=8765
TONELEAF_TRUSTED_HOSTS=127.0.0.1,localhost

# Optional: absolute path to an already-downloaded Hugging Face sequence
# classification model. Toneleaf uses local_files_only=True and never downloads.
# TONELEAF_MODEL_PATH=C:\models\sentiment-roberta
